# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Supabase Postgres (Session pooler, IPv4) ---
# Dashboard → Connect → "Session pooler". Swap [YOUR-PASSWORD] for your DB password.
SUPABASE_DB_DSN=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres

# --- GitHub personal access token (classic; no scopes needed for public read) ---
GITHUB_TOKEN=ghp_your_token_here

# --- Product Hunt API developer token ---
PH_TOKEN=your_ph_developer_token_here

# --- Collector universe: start small, comma-separated GitHub search fragments ---
GITHUB_QUERIES=language:rust,language:typescript
